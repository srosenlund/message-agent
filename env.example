# InboxForge AIO - Environment Configuration
# Copy this file to .env and configure your values

# ============================================================================
# Matrix Homeserver (Conduit)
# ============================================================================
MATRIX_SERVER_NAME=localhost
REGISTRATION_TOKEN=change-this-secret-token

# ============================================================================
# API Configuration
# ============================================================================
API_PORT=3000

# OpenAI Configuration (for AI draft suggestions)
OPENAI_API_KEY=sk-your-openai-api-key-here
OPENAI_MODEL=gpt-4-turbo-preview

# Matrix Bot Token (generate after creating bot user)
MATRIX_BOT_TOKEN=
MATRIX_HOMESERVER_URL=http://localhost:6167

# ============================================================================
# Outlook Bridge Configuration
# ============================================================================
BRIDGE_PORT=9000
BRIDGE_OUTLOOK_URL=http://localhost:9000

# Microsoft Graph API Credentials
# Get these from Azure Portal: https://portal.azure.com
GRAPH_CLIENT_ID=your-azure-app-client-id
GRAPH_CLIENT_SECRET=your-azure-app-client-secret
GRAPH_TENANT_ID=common
GRAPH_REDIRECT_URI=http://localhost:9000/oauth/callback

# AppService Tokens (generate with: node apps/bridge-outlook/register.js)
AS_TOKEN_OUTLOOK=
HS_TOKEN_OUTLOOK=

# ============================================================================
# Production Overrides (for deployment)
# ============================================================================
# MATRIX_SERVER_NAME=your-domain.com
# GRAPH_REDIRECT_URI=https://your-domain.com/oauth/callback
# BRIDGE_OUTLOOK_URL=https://your-domain.com

